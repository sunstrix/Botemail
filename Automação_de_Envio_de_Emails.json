{
  "name": "Envio de E-mails em Massa (Corrigido)",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "minutes",
              "minutesInterval": 1440
            }
          ]
        }
      },
      "id": "4e1f5d6e-8a2b-4c3d-9e0f-1a2b3c4d5e6f",
      "name": "Agendamento Diário",
      "type": "n8n-nodes-base.ScheduleTrigger",
      "typeVersion": 1,
      "position": [250, 300]
    },
    {
      "parameters": {
        "operation": "read",
        "filePath": "/home/node/.n8n-files/contatos.xlsx",
        "binaryPropertyName": "data"
      },
      "id": "2f3e4d5c-6b7a-8c9d-0e1f-2a3b4c5d6e7f",
      "name": "Ler Planilha",
      "type": "n8n-nodes-base.ReadWriteFile",
      "typeVersion": 1,
      "position": [450, 300]
    },
    {
      "parameters": {
        "fileContent": "data",
        "options": {
          "headerRow": true,
          "sheetName": "Sheet1"
        }
      },
      "id": "3a4b5c6d-7e8f-9a0b-1c2d-3e4f5a6b7c8d",
      "name": "Extrair Dados",
      "type": "n8n-nodes-base.ExtractFromFile",
      "typeVersion": 1,
      "position": [650, 300]
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Este nó tem 2 outputs:\n// Output 0: todos os itens originais com _index\n// Output 1: apenas itens com Status vazio (candidatos)\nconst allItems = $input.all();\nconst todos = [];\nconst candidatos = [];\nfor (let i = 0; i < allItems.length; i++) {\n    const item = allItems[i];\n    // Garantir campos\n    item.json.Nome = item.json.Nome || '';\n    item.json.Email = item.json.Email || '';\n    item.json.Status = item.json.Status || '';\n    // Adicionar índice\n    item.json._index = i;\n    todos.push(item);\n    // Verificar se Status está vazio\n    const status = item.json.Status;\n    if (status === '' || status == null || status === undefined) {\n        candidatos.push(item);\n    }\n}\nreturn [todos, candidatos];",
        "mode": "runOnceForEachItem"
      },
      "id": "5b6c7d8e-9f0a-1b2c-3d4e-5f6a7b8c9d0e",
      "name": "Preparar e Separar",
      "type": "n8n-nodes-base.Code",
      "typeVersion": 2,
      "position": [850, 300]
    },
    {
      "parameters": {
        "value": 200,
        "mode": "limit"
      },
      "id": "6c7d8e9f-0a1b-2c3d-4e5f-6a7b8c9d0e1f",
      "name": "Limitar 200",
      "type": "n8n-nodes-base.Limit",
      "typeVersion": 1,
      "position": [1050, 450]
    },
    {
      "parameters": {
        "email": "{{ $json.Email }}",
        "subject": "Sua mensagem personalizada",
        "text": "Olá {{ $json.Nome }},\n\nEste é um e-mail automático.",
        "options": {
          "continueOnError": true
        }
      },
      "id": "7d8e9f0a-1b2c-3d4e-5f6a-7b8c9d0e1f2a",
      "name": "Enviar E-mail",
      "type": "n8n-nodes-base.EmailSend",
      "typeVersion": 1,
      "position": [1250, 450],
      "continueOnFail": true
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const items = $input.all();\nconst now = new Date();\nconst dataHora = now.toLocaleString('pt-BR', { timeZone: 'America/Sao_Paulo' });\nfor (const item of items) {\n    const erro = item.json.error;\n    if (erro) {\n        item.json.Status = `Erro: ${erro.message || erro}`;\n    } else {\n        item.json.Status = `Enviado em ${dataHora}`;\n    }\n}\nreturn items;"
      },
      "id": "8e9f0a1b-2c3d-4e5f-6a7b-8c9d0e1f2a3b",
      "name": "Atualizar Status",
      "type": "n8n-nodes-base.Code",
      "typeVersion": 2,
      "position": [1450, 450]
    },
    {
      "parameters": {
        "inputs": 2
      },
      "id": "9f0a1b2c-3d4e-5f6a-7b8c-9d0e1f2a3b4c",
      "name": "Merge (dois inputs)",
      "type": "n8n-nodes-base.Merge",
      "typeVersion": 2,
      "position": [1450, 300],
      "inputs": 2
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Input 0: todos os originais\n// Input 1: processados (já com Status atualizado)\nconst originais = $input.all()[0];\nconst processados = $input.all()[1];\nconst mapa = new Map();\nfor (const p of processados) {\n    mapa.set(p.json._index, p.json.Status);\n}\nconst resultado = [];\nfor (const item of originais) {\n    const idx = item.json._index;\n    if (mapa.has(idx)) {\n        item.json.Status = mapa.get(idx);\n    }\n    delete item.json._index;\n    resultado.push(item);\n}\nreturn resultado;"
      },
      "id": "0a1b2c3d-4e5f-6a7b-8c9d-0e1f2a3b4c5d",
      "name": "Mesclar e Remover _index",
      "type": "n8n-nodes-base.Code",
      "typeVersion": 2,
      "position": [1650, 300]
    },
    {
      "parameters": {
        "options": {
          "headerRow": true,
          "sheetName": "Sheet1"
        }
      },
      "id": "1b2c3d4e-5f6a-7b8c-9d0e-1f2a3b4c5d6e",
      "name": "Converter para XLSX",
      "type": "n8n-nodes-base.ConvertToXLSX",
      "typeVersion": 1,
      "position": [1850, 300]
    },
    {
      "parameters": {
        "operation": "write",
        "filePath": "/home/node/.n8n-files/contatos.xlsx",
        "binaryPropertyName": "data",
        "options": {
          "overwrite": true
        }
      },
      "id": "2c3d4e5f-6a7b-8c9d-0e1f-2a3b4c5d6e7f",
      "name": "Salvar Arquivo",
      "type": "n8n-nodes-base.ReadWriteFile",
      "typeVersion": 1,
      "position": [2050, 300]
    }
  ],
